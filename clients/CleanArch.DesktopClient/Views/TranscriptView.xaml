<UserControl x:Class="CleanArch.DesktopClient.Views.TranscriptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Back" Command="{Binding BackCommand}" />
            <TextBlock Text="Transcript" FontSize="16" Margin="10,0" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock><Run Text="GPA: " FontWeight="Bold" /><Run Text="{Binding CumulativeGpa, StringFormat=0.00}" /></TextBlock>
            <TextBlock Margin="20,0,0,0"><Run Text="Standing: " FontWeight="Bold" /><Run Text="{Binding Standing}" /></TextBlock>
            <TextBlock Margin="20,0,0,0"><Run Text="Earned: " FontWeight="Bold" /><Run Text="{Binding EarnedCredits}" /></TextBlock>
            <TextBlock Margin="20,0,0,0"><Run Text="Attempted: " FontWeight="Bold" /><Run Text="{Binding AttemptedCredits}" /></TextBlock>
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Error}" Foreground="Red" Margin="0,5,0,0" />
        <DataGrid ItemsSource="{Binding Entries}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding CourseCode}" Width="100" />
                <DataGridTextColumn Header="Course" Binding="{Binding CourseTitle}" Width="*" />
                <DataGridTextColumn Header="Term" Binding="{Binding Term}" Width="100" />
                <DataGridTextColumn Header="Credits" Binding="{Binding Credits}" Width="70" />
                <DataGridTextColumn Header="Grade" Binding="{Binding Grade}" Width="70" />
                <DataGridTextColumn Header="Points" Binding="{Binding GradePoints, StringFormat=0.0}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
