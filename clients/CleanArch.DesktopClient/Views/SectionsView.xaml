<UserControl x:Class="CleanArch.DesktopClient.Views.SectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Back" Command="{Binding BackCommand}" Margin="0,0,10,0" />
            <TextBlock Text="Term:" VerticalAlignment="Center" Margin="0,0,5,0" />
            <TextBox Text="{Binding TermFilter, UpdateSourceTrigger=PropertyChanged}" Width="120" />
            <Button Content="Search" Command="{Binding SearchCommand}" Margin="5,0,0,0" />
            <Button Content="Open" Command="{Binding ViewDetailCommand}" Margin="5,0,0,0" />
            <Button Content="Browse courses…" Command="{Binding BrowseCoursesCommand}" Margin="15,0,0,0" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Prev" Command="{Binding PreviousPageCommand}" />
            <TextBlock Margin="10,0" VerticalAlignment="Center">
                <Run Text="Page " /><Run Text="{Binding Page}" /><Run Text=" / " /><Run Text="{Binding TotalPages}" />
                <Run Text="  (" /><Run Text="{Binding TotalCount}" /><Run Text=" total)" />
            </TextBlock>
            <Button Content="Next" Command="{Binding NextPageCommand}" />
            <TextBlock Text="{Binding Error}" Foreground="Red" Margin="20,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <DataGrid ItemsSource="{Binding Sections}" SelectedItem="{Binding SelectedSection}"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Course" Binding="{Binding CourseCode}" Width="100" />
                <DataGridTextColumn Header="Title" Binding="{Binding CourseTitle}" Width="*" />
                <DataGridTextColumn Header="Term" Binding="{Binding Term}" Width="90" />
                <DataGridTextColumn Header="Section" Binding="{Binding SectionCode}" Width="80" />
                <DataGridTextColumn Header="Instructor" Binding="{Binding InstructorName}" Width="*" />
                <DataGridTextColumn Header="Enrolled" Binding="{Binding EnrolledCount}" Width="70" />
                <DataGridTextColumn Header="Capacity" Binding="{Binding Capacity}" Width="70" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
